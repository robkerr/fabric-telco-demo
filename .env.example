# Copy this file to .env and fill in the values. .env is git-ignored (never commit secrets).
# Keys are grouped by phase; each script reads only what it needs. Values shown are examples
# or safe defaults — replace the GUIDs/names with your own.

# ============================ Fabric / workspace ============================
# Your existing Fabric workspace (on an F2+ capacity). Scripts create items *inside* it.
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_CAPACITY_ID=
FABRIC_LAKEHOUSE_NAME=lh_telco
# Written by scripts/10_provision_fabric.ps1 after it creates/reuses the Lakehouse:
FABRIC_LAKEHOUSE_ID=
FABRIC_API_BASE=https://api.fabric.microsoft.com/v1

# ---- Real-Time Intelligence (Eventhouse / KQL) — scripts/30_provision_eventhouse.ps1 ----
# The Eventhouse holds two customer-keyed real-time tables (OutageEvents, WebSessions).
# EVENTHOUSE_NAME is your chosen name; the script writes the resolved DB name + query URI.
EVENTHOUSE_NAME=telco_realtime
KQL_DATABASE_NAME=
KQL_QUERY_URI=

# ============================ Azure / Entra ============================
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
# Region + resource group of the reused Foundry resources (this demo used westus3 /
# rg-fabric-ai-demos). Point these at your own existing AI Foundry resource group.
AZURE_LOCATION=westus3
AZURE_RESOURCE_GROUP=rg-fabric-ai-demos

# ============================ Service principal (setup_spn.ps1) ============================
# setup_spn.ps1 creates the SPN, grants it workspace admin, and writes these back.
SPN_APP_ID=
SPN_TENANT_ID=
SPN_CLIENT_SECRET=            # secret — never commit
SPN_DISPLAY_NAME=sp-telco-fabric-demo

# ============================ Data generation ============================
DATA_CUSTOMERS=1000
DATA_SEED=42

# ============================ Fabric Data Agent ============================
# Populated after you publish the data agent (05_create_data_agent notebook + Fabric UI).
DATA_AGENT_NAME=TelcoCustomerServiceAgent
# The data agent (artifact) id = the GUID in the agent URL. Foundry (Phase 3) binds using
# FABRIC_WORKSPACE_ID + this id.
DATA_AGENT_ARTIFACT_ID=
# MCP endpoint. NOT the ".../aiassistant/openai" URL. The MCP URL has a "/mcp/" segment and
# ends in "/agent". Find it in the agent settings -> "Model Context Protocol" tab, or build it:
#   https://api.fabric.microsoft.com/v1/mcp/workspaces/{FABRIC_WORKSPACE_ID}/dataagents/{DATA_AGENT_ARTIFACT_ID}/agent
DATA_AGENT_MCP_ENDPOINT=
# (A second, ontology-backed data agent — "TelcoOntologyDataAgent" — can also be published for
#  graph/relationship questions; point FABRIC_CONNECTION_NAME at whichever you connect in Foundry.)

# ============================ Azure AI Foundry (existing project) ============================
# The Foundry *project* endpoint (Foundry portal -> project -> Overview). gpt-4.1 must be
# deployed on the project's account (see foundry/README.md for the required resources).
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-4.1
# Optional: only needed if auto-discovery can't resolve the account/project (setup_tracing.ps1):
# FOUNDRY_ACCOUNT_NAME=
# FOUNDRY_PROJECT_NAME=

# ============================ Foundry agent tool connections (Phase 3) ============================
# Agent tools bind to project *connections* you create in the Foundry portal. deploy_agents.ps1
# attaches whatever it finds and logs any it can't, so you can create a connection and re-run.
# Microsoft Fabric connection pointing at your published data agent (workspace + artifact id):
FABRIC_CONNECTION_NAME=TelcoCustomerServiceAgent
# Azure AI Search connection (name of the connection in the project) + the index name:
AI_SEARCH_ENDPOINT=
AI_SEARCH_CONNECTION_NAME=
AI_SEARCH_INDEX=telco-knowledge
# Optional: admin key for setup_knowledge.py to build the index. Prefer RBAC (Search Index Data
# Contributor) where keys are disallowed; leave blank to use your Entra identity.
AI_SEARCH_ADMIN_KEY=
# Optional Bing grounding connection for Web IQ:
BING_CONNECTION_NAME=

# ============================ Foundry tracing (foundry/setup_tracing.ps1) ============================
# setup_tracing.ps1 provisions a workspace-based Application Insights, connects it to the
# project (portal Tracing tab), and writes these two values.
APP_INSIGHTS_NAME=
# Connection string for optional client-side (web app) OpenTelemetry export:
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ============================ Web app / App Service (optional) ============================
# Only needed if you deploy the web app to Azure App Service (app/deploy_app.ps1). The web app
# also runs fully locally against the committed CSV sample data (see app/README.md).
APP_SERVICE_NAME=
KEY_VAULT_NAME=
# Optional live-data path: set both to hydrate the 360 profile from Fabric instead of local CSV.
# FABRIC_SQL_ENDPOINT=
