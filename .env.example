# ---- Fabric / workspace ----
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
FABRIC_CAPACITY_ID=
FABRIC_LAKEHOUSE_NAME=lh_telco
FABRIC_API_BASE=https://api.fabric.microsoft.com/v1

# ---- Azure / Entra ----
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=rg-telco-ai-demo

# ---- Service principal (populated by setup_spn.ps1) ----
SPN_APP_ID=
SPN_TENANT_ID=
# Secret is written to .env by setup_spn.ps1; never commit it.
SPN_CLIENT_SECRET=
SPN_DISPLAY_NAME=sp-telco-fabric-demo

# ---- Data generation ----
DATA_CUSTOMERS=1000
DATA_SEED=42

# ---- Fabric Data Agent (populated after you publish the 05_create_data_agent notebook's agent) ----
DATA_AGENT_NAME=TelcoCustomerServiceAgent
# The data agent (artifact) id - the guid in the agent URL. This is the value that matters most;
# Foundry (Phase 3) binds using FABRIC_WORKSPACE_ID + this id.
DATA_AGENT_ARTIFACT_ID=
# The MCP (Model Context Protocol) endpoint. NOTE: this is NOT the ".../aiassistant/openai" URL
# shown in some UI panels (that is the OpenAI-compatible endpoint). The MCP URL has a "/mcp/"
# segment and ends in "/agent". Find it in the data agent settings -> "Model Context Protocol"
# tab (copy "MCP server URL"), or build it from the two ids:
#   https://api.fabric.microsoft.com/v1/mcp/workspaces/{FABRIC_WORKSPACE_ID}/dataagents/{DATA_AGENT_ARTIFACT_ID}/agent
DATA_AGENT_MCP_ENDPOINT=

# ---- Azure AI Foundry (populated by infra/deploy.ps1) ----
FOUNDRY_PROJECT_ENDPOINT=
AI_SEARCH_ENDPOINT=
APP_SERVICE_NAME=
KEY_VAULT_NAME=

# ---- Foundry agent tool connections (Phase 3) ----
# Agent tools bind to project *connections* you create in the Foundry portal. Put their
# names here so foundry/deploy_agents.ps1 can attach them. deploy_agents attaches whatever
# it finds and logs any it can't, so you can create a connection and re-run.
FOUNDRY_MODEL=gpt-4.1
# Microsoft Fabric connection pointing at your published data agent (workspace + artifact id):
FABRIC_CONNECTION_NAME=
# Azure AI Search connection (to the search service from Phase 2) + the index name:
AI_SEARCH_CONNECTION_NAME=
AI_SEARCH_INDEX=telco-knowledge
# Optional Bing grounding connection for Web IQ:
BING_CONNECTION_NAME=

# ---- Foundry tracing / observability (foundry/setup_tracing.ps1) ----
# setup_tracing.ps1 provisions a workspace-based Application Insights and connects it to the
# Foundry project (portal Tracing tab + Agent Service traces). It writes the two values below.
# Optional overrides: FOUNDRY_ACCOUNT_NAME, FOUNDRY_PROJECT_NAME, LOG_ANALYTICS_WORKSPACE_NAME.
APP_INSIGHTS_NAME=
# Connection string for optional client-side (web app) OpenTelemetry export:
APPLICATIONINSIGHTS_CONNECTION_STRING=
